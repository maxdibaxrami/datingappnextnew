# Server-only Supabase configuration. Never prefix these with NEXT_PUBLIC_.
SUPABASE_URL=https://ergovlorwmexcnjsdanv.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_lp0mavUl1XY9ZWwuABNUPg_1Z8CTFsO
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVyZ292bG9yd21leGNuanNkYW52Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4Mzg2NTkzMywiZXhwIjoyMDk5NDQxOTMzfQ.R39tLoisy0fLRQoVRVATvOLrK37_ADSkSszGlm0gqWI

# Telegram BotFather token used only to verify Mini App initData on the server.
TELEGRAM_BOT_TOKEN=7599795722:AAGzL52hEDOxiIbxSZtpnqU_5yIUsT6NrUY

# Telegram Stars webhook secret sent by Telegram in
# X-Telegram-Bot-Api-Secret-Token. Generate a separate random value.
TELEGRAM_PAYMENT_WEBHOOK_SECRET=replace_with_at_least_20_random_characters

# TON payment verification. The receiver address is the only address invoices
# may target. The server, not the client, fixes the payment network.
# TONAPI_BASE_URL is normally https://tonapi.io for mainnet.
TON_PAYMENT_RECEIVER_ADDRESS=replace_with_your_ton_receiver_address
TON_PAYMENT_NETWORK=ton_mainnet
TONAPI_BASE_URL=https://tonapi.io
TONAPI_KEY=replace_with_tonapi_key

# Independent random secrets (at least 32 characters each). Keep stable.
# Changing TELEGRAM_AUTH_SECRET changes deterministic Telegram Auth IDs.
# Hint: You can generate 32-char random strings using `openssl rand -hex 16`
TELEGRAM_AUTH_SECRET=replace_with_at_least_32_random_characters
RATE_LIMIT_SECRET=replace_with_at_least_32_random_characters

# Comma-separated allowed application origins. Include local development.
APP_ORIGINS=https://your-real-mini-app-domain.com,https://localhost:3000,https://172.20.10.8:3000,https://127.0.0.1:3000
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=700

# Set automatically by most hosting providers.
NODE_ENV=development
